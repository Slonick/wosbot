<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="550.0" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <ScrollPane fitToWidth="true" fitToHeight="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;" vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308">
            <content>
                <VBox spacing="14" style="-fx-background-color: #1f1f1f; -fx-background-radius: 8; -fx-padding: 18;" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" VBox.vgrow="ALWAYS">
                    <children>
                        <!-- Top Controls: Refresh & Reset -->
                        <HBox alignment="CENTER_RIGHT" spacing="15">
                            <children>
                                <Button fx:id="btnRefresh" mnemonicParsing="false" onAction="#handleRefresh" style="-fx-background-color: #2b2b2b; -fx-text-fill: white; -fx-border-color: #444; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 6 15;" text="Refresh" />
                                <Button fx:id="btnReset" mnemonicParsing="false" onAction="#handleReset" style="-fx-background-color: #4a1c1c; -fx-text-fill: white; -fx-border-color: #662222; -fx-border-radius: 4; -fx-background-radius: 4; -fx-padding: 6 15;" text="Reset Statistics" />
                            </children>
                        </HBox>

                        <Separator style="-fx-opacity: 0.3;" />

                        <!-- Summary Cards Row -->
                        <HBox fx:id="hboxSummaryCards" spacing="15" alignment="CENTER" />

                        <Separator style="-fx-opacity: 0.3;" />

                        <Label text="Task Execution Statistics" style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-padding: 10 0 5 0;" />
                        <TableView fx:id="tableTasks" minHeight="300.0" prefHeight="450.0" VBox.vgrow="ALWAYS" style="-fx-background-color: #242424; -fx-control-inner-background: #242424; -fx-table-cell-border-color: transparent; -fx-table-header-border-color: #333; -fx-padding: 0; -fx-border-color: #333; -fx-border-radius: 6; -fx-background-radius: 6;">
                            <columns>
                                <TableColumn fx:id="colTaskName" prefWidth="200.0" text="Task Name" />
                                <TableColumn fx:id="colRuns" prefWidth="80.0" text="Runs" />
                                <TableColumn fx:id="colAvgTime" prefWidth="120.0" text="Avg Time (s)" />
                                <TableColumn fx:id="colTotalTime" prefWidth="120.0" text="Total Time (s)" />
                                <TableColumn fx:id="colAvgOcr" prefWidth="100.0" text="Avg OCR Fail" />
                                <TableColumn fx:id="colAvgImg" prefWidth="100.0" text="Avg Img Fail" />
                                <TableColumn fx:id="colLastRun" prefWidth="150.0" text="Last Run" />
                            </columns>
                        </TableView>

                        <Separator style="-fx-opacity: 0.3;" />

                        <Label text="Activity Counters" style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-padding: 15 0 5 0;" />

                        <!-- Dynamic grouped counter sections will be added here -->
                        <VBox fx:id="vboxCounterSections" spacing="10" />

                        <!-- Empty State message -->
                        <Label fx:id="lblNoData" style="-fx-text-fill: #888888; -fx-font-style: italic; -fx-padding: 20;" text="No statistics recorded yet..." visible="false" managed="false" />

                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</VBox>
