<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
      prefHeight="550.0" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS"
      xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <ScrollPane fitToWidth="true" fitToHeight="true" hbarPolicy="NEVER"
                    vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS"
                    maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308">
            <content>
                <VBox spacing="14" style="-fx-padding: 18;"
                      maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" VBox.vgrow="ALWAYS">
                    <children>
                        <!-- Top Controls: Refresh & Reset -->
                        <HBox alignment="CENTER_RIGHT" spacing="15">
                            <children>
                                <Button fx:id="btnRefresh" mnemonicParsing="false"
                                        onAction="#handleRefresh" text="Refresh" />
                                <Button fx:id="btnReset" mnemonicParsing="false"
                                        onAction="#handleReset" text="Reset Statistics"
                                        style="-fx-text-fill: #f85149;" />
                            </children>
                        </HBox>

                        <Separator style="-fx-opacity: 0.3;" />

                        <!-- Summary Cards Row -->
                        <HBox fx:id="hboxSummaryCards" spacing="15" alignment="CENTER" />

                        <Separator style="-fx-opacity: 0.3;" />

                        <Label text="Task Execution Statistics" styleClass="section-title" />
                        <TableView fx:id="tableTasks" minHeight="300.0" prefHeight="450.0" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colTaskName" prefWidth="200.0" text="Task Name" />
                                <TableColumn fx:id="colRuns" prefWidth="80.0" text="Runs" />
                                <TableColumn fx:id="colAvgTime" prefWidth="120.0" text="Avg Time (s)" />
                                <TableColumn fx:id="colTotalTime" prefWidth="120.0" text="Total Time (s)" />
                                <TableColumn fx:id="colAvgOcr" prefWidth="100.0" text="Avg OCR Fail" />
                                <TableColumn fx:id="colAvgImg" prefWidth="100.0" text="Avg Img Fail" />
                                <TableColumn fx:id="colLastRun" prefWidth="150.0" text="Last Run" />
                            </columns>
                        </TableView>

                        <Separator style="-fx-opacity: 0.3;" />

                        <Label text="Activity Counters" styleClass="section-title" />

                        <!-- Dynamic grouped counter sections will be added here -->
                        <VBox fx:id="vboxCounterSections" spacing="10" />

                        <!-- Empty State message -->
                        <Label fx:id="lblNoData" styleClass="label-muted"
                               text="No statistics recorded yet..." visible="false" managed="false" />

                    </children>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</VBox>
