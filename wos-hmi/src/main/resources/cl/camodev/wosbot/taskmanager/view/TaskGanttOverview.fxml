<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<VBox spacing="16" styleClass="task-page-root" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="cl.camodev.wosbot.taskmanager.view.TaskGanttOverviewController">
    <!-- Title, Legend and View Toggle -->
    <HBox spacing="20" style="-fx-padding: 0 0 12 0;" alignment="CENTER_LEFT">
        <children>
            <Label text="📊 Task Timeline" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: -wos-yellow;" />

            <!-- Legend -->
            <HBox spacing="15" alignment="CENTER_LEFT">
                <children>
                    <HBox spacing="5" alignment="CENTER_LEFT">
                        <Rectangle width="16" height="16" style="-fx-fill: -wos-yellow; -fx-stroke: -wos-text-dark; -fx-stroke-width: 2; -fx-arc-width: 3; -fx-arc-height: 3;" />
                        <Label text="Running" styleClass="task-field-label" />
                    </HBox>
                    <HBox spacing="5" alignment="CENTER_LEFT">
                        <Rectangle width="16" height="16" style="-fx-fill: -wos-green; -fx-arc-width: 3; -fx-arc-height: 3;" />
                        <Label text="Ready" styleClass="task-field-label" />
                    </HBox>
                    <HBox spacing="5" alignment="CENTER_LEFT">
                        <Rectangle width="16" height="16" style="-fx-fill: -wos-blue; -fx-arc-width: 3; -fx-arc-height: 3;" />
                        <Label text="Scheduled" styleClass="task-field-label" />
                    </HBox>
                    <HBox spacing="5" alignment="CENTER_LEFT">
                        <Rectangle width="16" height="16" style="-fx-fill: -wos-border-subtle; -fx-stroke: -wos-text-secondary; -fx-stroke-width: 1; -fx-arc-width: 3; -fx-arc-height: 3;" />
                        <Label text="Inactive" styleClass="task-field-label" />
                    </HBox>
                </children>
            </HBox>

            <Region HBox.hgrow="ALWAYS" />

            <!-- View Toggle -->
            <HBox spacing="8" alignment="CENTER_RIGHT">
                <ToggleButton fx:id="toggleInactiveTasksButton" text="Hide inactive" style="-fx-font-size: 11; -fx-background-color: -wos-bg-card; -fx-text-fill: -wos-text-primary; -fx-padding: 4 12; -fx-border-color: -wos-border-subtle; -fx-border-radius: 4; -fx-background-radius: 4;" onAction="#toggleInactiveTasks" />
                <Label text="View:" styleClass="task-field-label" />
                <ToggleButton fx:id="toggleViewButton" text="2 Hours" style="-fx-font-size: 11; -fx-background-color: -wos-bg-card; -fx-text-fill: -wos-yellow; -fx-padding: 4 12; -fx-border-color: -wos-yellow; -fx-border-radius: 4; -fx-background-radius: 4;" onAction="#toggleTimeView" />
            </HBox>
        </children>
    </HBox>

    <!-- Header: Time Axis (dynamically generated) -->
    <HBox fx:id="timeAxisContainer" spacing="0" style="-fx-padding: 0 0 8 0;" alignment="CENTER_LEFT">
        <children>
            <Label text="Account" style="-fx-font-weight: bold; -fx-text-fill: -wos-yellow; -fx-pref-width: 128; -fx-font-size: 12;" />
            <HBox fx:id="timeAxisHeader" spacing="0" alignment="CENTER_LEFT" />
        </children>
    </HBox>

    <!-- Scrollable task list -->
    <ScrollPane fx:id="scrollPane" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="task-page-scroll" VBox.vgrow="ALWAYS">
        <content>
            <VBox fx:id="vboxAccounts" spacing="0" style="-fx-background-color: transparent;" />
        </content>
    </ScrollPane>
</VBox>
