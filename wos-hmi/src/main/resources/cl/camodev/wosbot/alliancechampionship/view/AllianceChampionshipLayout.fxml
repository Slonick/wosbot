<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<GridPane hgap="20" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
          prefHeight="400.0" prefWidth="720.0"
          xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="18" left="18" right="18" top="18" />
    </padding>
    <columnConstraints>
        <ColumnConstraints percentWidth="70" />
        <ColumnConstraints percentWidth="30" />
    </columnConstraints>
    <rowConstraints>
        <RowConstraints vgrow="ALWAYS" />
    </rowConstraints>
    <children>
        <!-- Main content panel -->
        <VBox styleClass="task-page-root" GridPane.columnIndex="0" GridPane.rowIndex="0">
            <children>
                <CheckBox fx:id="checkBoxEnableChampionship" mnemonicParsing="false"
                          style="-fx-font-size: 15px; -fx-font-weight: bold;" text="Enable Alliance Championship" />

                <Label styleClass="task-card-description"
                       text="Deploy troops to Alliance Championship with customizable formation and position."
                       wrapText="true" />

                <!-- Deployment Settings Card -->
                <VBox styleClass="content-card">
                    <children>
                        <HBox maxWidth="1.7976931348623157E308" styleClass="header-blue">
                            <children>
                                <Label text="Deployment Configuration" />
                            </children>
                        </HBox>
                        <VBox styleClass="task-section-inner">
                            <children>
                                <CheckBox fx:id="checkBoxOverrideCurrentDeploy" mnemonicParsing="false"
                                          text="Override current deployment" />
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <children>
                                        <Label styleClass="task-field-label" text="Position" minWidth="100.0" />
                                        <ComboBox fx:id="comboBoxPosition" prefWidth="150.0" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </VBox>

                <!-- Troop Distribution Card -->
                <VBox styleClass="content-card">
                    <children>
                        <HBox maxWidth="1.7976931348623157E308" styleClass="header-orange">
                            <children>
                                <Label text="Troop Distribution (%)" />
                            </children>
                        </HBox>
                        <GridPane hgap="16" maxWidth="1.7976931348623157E308"
                                  styleClass="task-section-inner" vgap="12">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="33.33" />
                                <ColumnConstraints percentWidth="33.33" />
                                <ColumnConstraints percentWidth="33.34" />
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints />
                            </rowConstraints>
                            <children>
                                <VBox spacing="6" GridPane.columnIndex="0">
                                    <children>
                                        <Label styleClass="task-field-label" text="Infantry" />
                                        <TextField fx:id="textfieldInfantryPercentage" prefWidth="80.0" promptText="33" />
                                    </children>
                                </VBox>
                                <VBox spacing="6" GridPane.columnIndex="1">
                                    <children>
                                        <Label styleClass="task-field-label" text="Lancers" />
                                        <TextField fx:id="textfieldLancersPercentage" prefWidth="80.0" promptText="33" />
                                    </children>
                                </VBox>
                                <VBox spacing="6" GridPane.columnIndex="2">
                                    <children>
                                        <Label styleClass="task-field-label" text="Marksmans" />
                                        <TextField fx:id="textfieldMarksmansPercentage" prefWidth="80.0" promptText="34" />
                                    </children>
                                </VBox>
                            </children>
                        </GridPane>
                    </children>
                </VBox>
            </children>
        </VBox>

        <!-- Info panel -->
        <VBox alignment="TOP_LEFT" styleClass="task-info-panel"
              GridPane.columnIndex="1" GridPane.rowIndex="0">
            <children>
                <Label styleClass="task-info-panel-title" text="Alliance Championship" wrapText="true" />
                <Label text="" />
                <Label styleClass="task-info-panel-guide-header" text="Quick guide" />
                <Separator />
                <Label styleClass="task-info-panel-bullet" text="• Enable to activate the task." wrapText="true" />
                <Label styleClass="task-info-panel-bullet" text="• Override current deploy will replace existing deployment." wrapText="true" />
                <Label styleClass="task-info-panel-bullet" text="• Position: Select LEFT, CENTER, or RIGHT deployment slot." wrapText="true" />
                <Label styleClass="task-info-panel-bullet" text="• Set troop percentages - total must equal 100%." wrapText="true" />
                <Label styleClass="task-info-panel-bullet" text="• Task runs weekly: Monday 00:01 - Wednesday 22:55 UTC." wrapText="true" />
                <Separator />
            </children>
        </VBox>
    </children>
</GridPane>
