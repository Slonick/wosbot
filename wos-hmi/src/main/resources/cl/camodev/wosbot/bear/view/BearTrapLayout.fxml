<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.controlsfx.control.*?>

<GridPane hgap="20" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
          prefHeight="500.0" prefWidth="720.0"
          xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="18" left="18" right="18" top="18" />
    </padding>
    <columnConstraints>
        <ColumnConstraints percentWidth="70" />
        <ColumnConstraints percentWidth="30" />
    </columnConstraints>
    <rowConstraints>
        <RowConstraints vgrow="ALWAYS" />
    </rowConstraints>
    <children>
        <!-- Main content panel with ScrollPane -->
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                    styleClass="task-page-scroll"
                    GridPane.columnIndex="0" GridPane.rowIndex="0">
            <content>
                <VBox styleClass="task-page-root">
                    <children>
                        <!-- Enable toggle -->
                        <CheckBox fx:id="checkBoxEnableBearTrap" mnemonicParsing="false"
                                  style="-fx-font-size: 15px; -fx-font-weight: bold;" text="Enable Bear Trap" />

                        <Label styleClass="task-card-description"
                               text="Automate Bear Trap event with scheduled preparation and rally management."
                               wrapText="true" />

                        <!-- Trap Schedule Card -->
                        <VBox styleClass="content-card">
                            <children>
                                <HBox maxWidth="1.7976931348623157E308"
                                      styleClass="header-yellow">
                                    <children>
                                        <Label text="Trap Schedule" />
                                    </children>
                                </HBox>
                                <VBox styleClass="task-section-inner">
                                    <children>
                                        <VBox spacing="6">
                                            <children>
                                                <Label styleClass="task-field-label" text="Next Bear Trap (UTC)" />
                                                <TextField fx:id="textFieldScheduleDateTime" promptText="dd-MM-yyyy HH:mm" />
                                                <Label fx:id="labelDateTimeError"
                                                       style="-fx-font-size: 11px; -fx-text-fill: #ff4444;"
                                                       text="" wrapText="true" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="6">
                                            <children>
                                                <Label styleClass="task-field-label" text="Preparation Time (minutes)" />
                                                <TextField fx:id="textFieldPreparationTime" prefWidth="100.0" promptText="5" />
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                        <!-- Preparation Card -->
                        <VBox styleClass="content-card">
                            <children>
                                <HBox maxWidth="1.7976931348623157E308"
                                      styleClass="header-blue">
                                    <children>
                                        <Label text="Preparation" />
                                    </children>
                                </HBox>
                                <VBox styleClass="task-section-inner">
                                    <children>
                                        <CheckBox fx:id="checkBoxActivePets" mnemonicParsing="false" text="Active Pets" />
                                        <CheckBox fx:id="checkBoxRecallTroops" mnemonicParsing="false" text="Recall Gather Troops" />
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                        <!-- Trap Configuration Card -->
                        <VBox styleClass="content-card">
                            <children>
                                <HBox maxWidth="1.7976931348623157E308"
                                      styleClass="header-red">
                                    <children>
                                        <Label text="Trap Configuration" />
                                    </children>
                                </HBox>
                                <VBox styleClass="task-section-inner">
                                    <children>
                                        <!-- Trap Selection -->
                                        <HBox alignment="CENTER_LEFT" spacing="10">
                                            <children>
                                                <Label styleClass="task-field-label" text="Trap Number" minWidth="100.0" />
                                                <ComboBox fx:id="comboBoxTrapNumber" prefWidth="100.0" />
                                            </children>
                                        </HBox>

                                        <!-- Call Rally -->
                                        <VBox spacing="8">
                                            <children>
                                                <CheckBox fx:id="checkBoxCallRally" mnemonicParsing="false" text="Call Own Rally" />
                                                <HBox alignment="CENTER_LEFT" spacing="10">
                                                    <children>
                                                        <Label styleClass="task-field-label" text="Rally Flag" minWidth="100.0" />
                                                        <ComboBox fx:id="comboBoxRallyFlag" prefWidth="100.0" />
                                                    </children>
                                                    <padding>
                                                        <Insets left="20.0" />
                                                    </padding>
                                                </HBox>
                                            </children>
                                        </VBox>

                                        <!-- Join Rally -->
                                        <VBox spacing="8">
                                            <children>
                                                <CheckBox fx:id="checkBoxEnableJoin" mnemonicParsing="false" text="Enable Join Rally" />
                                                <HBox alignment="CENTER_LEFT" spacing="10">
                                                    <children>
                                                        <Label styleClass="task-field-label" text="Join Flag" minWidth="100.0" />
                                                        <CheckComboBox fx:id="checkComboBoxJoinFlag" prefWidth="100.0" />
                                                    </children>
                                                    <padding>
                                                        <Insets left="20.0" />
                                                    </padding>
                                                </HBox>
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>

        <!-- Info panel -->
        <VBox alignment="TOP_LEFT" styleClass="task-info-panel"
              GridPane.columnIndex="1" GridPane.rowIndex="0">
            <children>
                <Label styleClass="task-info-panel-title" text="Bear Trap Event" wrapText="true" />
                <Label text="" />
                <Label styleClass="task-info-panel-guide-header" text="Quick guide" />
                <Separator />
                <Label styleClass="task-info-panel-bullet" text="• Enable to activate the Bear Trap automation." wrapText="true" />
                <Label styleClass="task-info-panel-bullet" text="• Set next trap time in UTC format (dd-MM-yyyy HH:mm)." wrapText="true" />
                <Label styleClass="task-info-panel-bullet" text="• Preparation time: minutes before trap activation." wrapText="true" />
                <Label styleClass="task-info-panel-bullet" text="• Active Pets will be enabled during preparation." wrapText="true" />
                <Label styleClass="task-info-panel-bullet" text="• Recall troops will return your gathering marches." wrapText="true" />
                <Label styleClass="task-info-panel-bullet" text="• Call Rally to start your own rally on the trap." wrapText="true" />
                <Label styleClass="task-info-panel-bullet" text="• Join Rally to join existing rallies automatically." wrapText="true" />
                <Label styleClass="task-info-panel-bullet" text="• Gather and Autojoin will be rescheduled at end to send marches again." wrapText="true" />
                <Separator />
            </children>
        </VBox>
    </children>
</GridPane>
