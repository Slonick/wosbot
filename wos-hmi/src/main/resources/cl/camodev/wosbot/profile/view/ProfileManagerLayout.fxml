<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
      spacing="0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">
   <children>

      <!-- Profile Table -->
      <TableView fx:id="tableviewLogMessages" VBox.vgrow="ALWAYS"
                 maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308">
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
         <columns>
            <TableColumn fx:id="columnEnabled" maxWidth="90.0" minWidth="90.0"
                         prefWidth="90.0" resizable="false" text="ENABLED" style="-fx-alignment: CENTER;" />
            <TableColumn fx:id="columnEmulatorNumber" maxWidth="40.0" minWidth="40.0"
                         prefWidth="40.0" resizable="false" text="ID" style="-fx-alignment: CENTER;" />
            <TableColumn fx:id="columnProfileName" maxWidth="1.7976931348623157E308"
                         prefWidth="204.0" text="NAME" style="-fx-alignment: CENTER;" />
            <TableColumn fx:id="columnPriority" maxWidth="90.0" minWidth="90.0"
                         prefWidth="90.0" resizable="false" text="PRIORITY" style="-fx-alignment: CENTER;" />
            <TableColumn fx:id="columnStatus" maxWidth="200.0" minWidth="200.0"
                         prefWidth="200.0" resizable="false" text="STATUS" style="-fx-alignment: CENTER;" />
            <TableColumn fx:id="columnDelete" maxWidth="140.0" minWidth="140.0"
                         prefWidth="140.0" resizable="false" text="ACTIONS" style="-fx-alignment: CENTER;" />
         </columns>
      </TableView>

      <!-- Toolbar -->
      <HBox alignment="CENTER_RIGHT" spacing="8" style="-fx-padding: 10 12;">
         <children>
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="btnBulkUpdate" mnemonicParsing="false"
                    onAction="#handleButtonBulkUpdateProfiles" text="Bulk Update" />
            <Button fx:id="btnAddProfile" mnemonicParsing="false"
                    onAction="#handleButtonAddProfile" text="Add Profile" />
         </children>
      </HBox>

   </children>
</VBox>
