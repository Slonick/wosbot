<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17.0.12" fx:controller="cl.camodev.wosbot.taskmanager.view.ScheduleTaskDialogController"
      styleClass="task-page-root" prefHeight="350.0" prefWidth="440.0">
    <!-- Scheduled Task Card -->
    <VBox styleClass="content-card">
        <HBox alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308" styleClass="header-blue">
            <Label fx:id="lblTaskName" text="Schedule Task" />
        </HBox>
        <VBox styleClass="task-section-inner">
            <Label styleClass="task-card-description" text="Schedule exactly when to execute this task." wrapText="true" />
            <Separator style="-fx-opacity: 0.25;" />
            <GridPane hgap="10" vgap="10" prefWidth="414.0">
               <columnConstraints>
                  <ColumnConstraints hgrow="SOMETIMES" maxWidth="143.0" minWidth="10.0" prefWidth="143.0" />
                  <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="177.0" />
               </columnConstraints>
               <rowConstraints>
                  <RowConstraints minHeight="10.0" prefHeight="40.0" vgrow="SOMETIMES" />
                  <RowConstraints minHeight="10.0" prefHeight="40.0" vgrow="SOMETIMES" />
                  <RowConstraints minHeight="10.0" prefHeight="40.0" vgrow="SOMETIMES" />
                  <RowConstraints minHeight="10.0" prefHeight="40.0" vgrow="SOMETIMES" />
               </rowConstraints>
            
               <!-- Execution Options -->
               <Label styleClass="task-field-label" text="Execution:" GridPane.rowIndex="0">
                  <GridPane.margin>
                     <Insets right="10.0" />
                  </GridPane.margin>
               </Label>
               <CheckBox fx:id="cbImmediate" mnemonicParsing="false" text="Execute immediately" GridPane.columnIndex="1" GridPane.rowIndex="0" />
            
               <!-- Time Input -->
               <Label styleClass="task-field-label" text="Schedule time:" GridPane.rowIndex="1">
                  <GridPane.margin>
                     <Insets right="10.0" />
                  </GridPane.margin>
               </Label>
               <TextField fx:id="timeField" promptText="HH:MM:SS" GridPane.columnIndex="1" GridPane.rowIndex="1">
                  <GridPane.margin>
                     <Insets />
                  </GridPane.margin>
               </TextField>
            
               <!-- Recurring Option -->
               <Label styleClass="task-field-label" text="Recurrence:" GridPane.rowIndex="2">
                  <GridPane.margin>
                     <Insets right="10.0" />
                  </GridPane.margin>
               </Label>
               <CheckBox fx:id="cbRecurring" mnemonicParsing="false" text="Recurring execution" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            
               <!-- Info Label -->
               <Label fx:id="lblInfo" styleClass="task-card-note" text="" visible="false" wrapText="true" GridPane.columnSpan="2" GridPane.rowIndex="3">
                  <GridPane.margin>
                     <Insets top="10.0" />
                  </GridPane.margin>
               </Label>
            </GridPane>

           <!-- Button Container -->
           <HBox alignment="CENTER_RIGHT" spacing="10.0">
              <children>
                 <Button fx:id="btnCancel" mnemonicParsing="false" onAction="#handleCancel" styleClass="button" text="Cancel" />
                 <Button fx:id="btnSchedule" mnemonicParsing="false" onAction="#handleSchedule" styleClass="action-button-timeline" text="Schedule" />
              </children>
              <VBox.margin>
                 <Insets top="15.0" />
              </VBox.margin>
           </HBox>
        </VBox>
    </VBox>
</VBox>
